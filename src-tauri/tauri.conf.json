{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gemini-collector",
  "version": "0.1.0",
  "identifier": "com.gemini-collector.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gemini Chat",
        "width": 1100,
        "height": 720,
        "minWidth": 700,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/gemini_export.py": "./",
      "../scripts/gemini_worker.py": "./",
      "../scripts/gemini_protocol.py": "./",
      "../scripts/gemini_cookies.py": "./",
      "../scripts/gemini_turn_parser.py": "./",
      "../scripts/gemini_media.py": "./",
      "../scripts/gemini_storage.py": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
